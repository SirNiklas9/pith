{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "pith: read file",
      "type": "shell",
      "command": "pith",
      "args": ["read", "${file}", "--grep"],
      "presentation": { "reveal": "always", "panel": "shared", "focus": false },
      "problemMatcher": {
        "owner": "pith",
        "pattern": { "regexp": "^(.+):(\\d+):", "file": 1, "line": 2, "message": 3 }
      }
    },
    {
      "label": "pith: read folder",
      "type": "shell",
      "command": "pith",
      "args": ["read", "${fileDirname}"],
      "presentation": { "reveal": "always", "panel": "shared", "focus": false },
      "problemMatcher": []
    },
    {
      "label": "pith: search",
      "type": "shell",
      "command": "pith",
      "args": ["search", "${input:searchQuery}", "${workspaceFolder}", "-r"],
      "presentation": { "reveal": "always", "panel": "shared", "focus": false },
      "problemMatcher": {
        "owner": "pith",
        "pattern": { "regexp": "^(.+):(\\d+):", "file": 1, "line": 2, "message": 3 }
      }
    },
    {
      "label": "pith: summary",
      "type": "shell",
      "command": "pith",
      "args": ["summary", "${file}", "--agent", "claude --dangerously-skip-permissions -p"],
      "presentation": { "reveal": "always", "panel": "shared", "focus": true },
      "problemMatcher": []
    },
    {
      "label": "pith: explain at cursor",
      "type": "shell",
      "command": "pith",
      "args": ["explain", "${file}:${lineNumber}", "--agent", "claude --dangerously-skip-permissions -p"],
      "presentation": { "reveal": "always", "panel": "shared", "focus": true },
      "problemMatcher": []
    },
    {
      "label": "pith: explain by name",
      "type": "shell",
      "command": "pith",
      "args": ["explain", "${file}", "${input:explainName}", "--agent", "claude --dangerously-skip-permissions -p"],
      "presentation": { "reveal": "always", "panel": "shared", "focus": true },
      "problemMatcher": []
    },
    {
      "label": "pith: edit selection",
      "type": "shell",
      "command": "pith",
      "args": [
        "edit", "${file}",
        "--range", "${input:editRange}",
        "--prompt", "${input:editPrompt}",
        "--agent", "claude --dangerously-skip-permissions -p",
        "--apply"
      ],
      "presentation": { "reveal": "always", "panel": "shared", "focus": true },
      "problemMatcher": []
    },
    {
      "label": "pith: generate file",
      "type": "shell",
      "command": "pith",
      "args": [
        "generate", "${input:newFile}",
        "--prompt", "${input:generatePrompt}",
        "--agent", "claude --dangerously-skip-permissions -p",
        "--apply"
      ],
      "presentation": { "reveal": "always", "panel": "shared", "focus": true },
      "problemMatcher": []
    },
    {
      "label": "pith: work list",
      "type": "shell",
      "command": "pith",
      "args": ["work"],
      "presentation": { "reveal": "always", "panel": "shared", "focus": true },
      "problemMatcher": []
    },
    {
      "label": "pith: work add at cursor",
      "type": "shell",
      "command": "pith",
      "args": ["work", "add", "${input:workNote}", "--at", "${file}:${lineNumber}"],
      "presentation": { "reveal": "always", "panel": "shared", "focus": false },
      "problemMatcher": []
    }
  ],
  "inputs": [
    { "id": "searchQuery",    "type": "promptString", "description": "Search query" },
    { "id": "explainName",    "type": "promptString", "description": "Declaration name to explain" },
    { "id": "editRange",      "type": "promptString", "description": "Line range to edit (e.g. 10:30)" },
    { "id": "editPrompt",     "type": "promptString", "description": "Edit instruction" },
    { "id": "newFile",        "type": "promptString", "description": "New file path (relative to workspace)" },
    { "id": "generatePrompt", "type": "promptString", "description": "What to generate" },
    { "id": "workNote",       "type": "promptString", "description": "Work note to add" }
  ]
}
